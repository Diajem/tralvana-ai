# AI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=

# App
APP_ENV=development
API_PORT=8000
WEB_PORT=3000

# Frontend → API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Intelligence Gateway (travelos/intelligence_gateway/) — infrastructure only,
# no live provider is wired up yet. See docs/INTELLIGENCE_GATEWAY.md and
# docs/SECRET_MANAGEMENT.md. Placeholders only — never commit a real value.
PROVIDER_ENVIRONMENT=MOCK
PROVIDER_CACHE_ENABLED=true
PROVIDER_RETRY_ENABLED=true
PROVIDER_DEFAULT_PRIORITY=100
# Force a specific provider for one capability, e.g. PROVIDER_FLIGHTS=some_provider_name
# PROVIDER_FLIGHTS=
# PROVIDER_ACCOMMODATION=
# PROVIDER_WEATHER=

# Live Provider Framework (travelos/live_providers/, T-026) — foundation only,
# no real external API is connected. See docs/LIVE_PROVIDER_FRAMEWORK.md and
# docs/PRODUCTION_READINESS.md before ever setting a real value below.
# TRALVANA_PROVIDER_ENVIRONMENT is the preferred name for PROVIDER_ENVIRONMENT
# above (both work; this one takes precedence if both are set).
TRALVANA_PROVIDER_ENVIRONMENT=MOCK
PROVIDER_HTTP_TIMEOUT_SECONDS=10
PROVIDER_RETRY_MAX_ATTEMPTS=3
PROVIDER_HEALTHCHECK_ENABLED=true

# Example future live-provider credentials (SecretReference env vars) — unset,
# not required for current mock operation, no real key has been added; every
# registered provider today is a mock (docs/SECRET_MANAGEMENT.md).
#
# DUFFEL_API_TOKEN — the first real vendor adapter, T-027/T-037
# (docs/FIRST_LIVE_PROVIDER.md, docs/FLIGHT_PROVIDER_INTEGRATION.md).
# Use a duffel_test_... token, never duffel_live_.... Setting this alone
# does NOT enable live calls — see TRALVANA_FLIGHT_PROVIDER_MODE below.
# DUFFEL_API_TOKEN=
# AMADEUS_API_KEY=
# AMADEUS_API_SECRET=
# WEATHER_API_KEY=
# MAPS_API_KEY=

# Live Flight Search (T-038) — see docs/LIVE_FLIGHT_SEARCH.md and
# docs/DUFFEL_SANDBOX_OPERATIONS.md. FLIGHTS-specific — independent of
# PROVIDER_ENVIRONMENT/TRALVANA_PROVIDER_ENVIRONMENT above (which still
# governs Weather) and of TRALVANA_ACCOMMODATION_PROVIDER_MODE below.
# Never inferred from DUFFEL_API_TOKEN's presence. Changing this
# requires an application restart.
#
# MOCK (default) — no credential required, no network call ever made.
# LIVE_SANDBOX — requires DUFFEL_API_TOKEN; the application fails to
# start if it's missing (fail-fast, not a per-request error).
TRALVANA_FLIGHT_PROVIDER_MODE=MOCK
# If a LIVE_SANDBOX search fails (auth/timeout/rate-limit/unavailable),
# the API returns 503 by default. Set this to fall back to clearly-
# labelled mock data instead — never a silent, unlabelled substitution.
TRALVANA_FLIGHT_MOCK_FALLBACK_ENABLED=false

# Live Accommodation Search (T-039) — see docs/LIVE_ACCOMMODATION_SEARCH.md
# and docs/DUFFEL_STAYS_INTEGRATION.md. ACCOMMODATION-specific, same
# pattern and same DUFFEL_API_TOKEN as flights above, but independent —
# enabling one never enables the other. NOTE: as of this release, the
# Duffel account used for this repository's token does NOT have Stays
# access (a confirmed 403, "This feature is not enabled for your
# account") — setting this to LIVE_SANDBOX will register the provider
# successfully but every search will fail with a clear 503 until Stays
# access is separately requested (https://duffel.com/contact-us).
TRALVANA_ACCOMMODATION_PROVIDER_MODE=MOCK
TRALVANA_ACCOMMODATION_MOCK_FALLBACK_ENABLED=false
